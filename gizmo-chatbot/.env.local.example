# Copia este archivo como ".env.local" y rellena tu clave.
# .env.local NO se sube al repositorio (está en .gitignore).

# Clave de OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Opcional) Modelo a usar. Por defecto: openai/gpt-4o-mini
# Ejemplos gratis/baratos en OpenRouter:
#   openai/gpt-4o-mini
#   meta-llama/llama-3.1-8b-instruct
#   google/gemini-flash-1.5
OPENROUTER_MODEL=openai/gpt-4o-mini

# (Opcional) Para el ranking de OpenRouter. URL pública de tu despliegue.
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=Gizmo Chatbot
